{
    "name": "relova/core",
    "description": "Relova — Universal Data Connector Platform. Virtual-first data federation for Laravel applications.",
    "version": "1.0.0",
    "type": "library",
    "license": "proprietary",
    "keywords": ["data-connector", "federation", "virtual", "database", "laravel"],
    "authors": [
        {
            "name": "Relova Team"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/encryption": "^11.0|^12.0",
        "illuminate/cache": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Relova\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Relova\\RelovaServiceProvider"
            ],
            "aliases": {
                "Relova": "Relova\\Facades\\Relova"
            }
        }
    },
    "minimum-stability": "stable"
}
